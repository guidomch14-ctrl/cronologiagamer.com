  .header { grid-area: header; padding: 19px 0px; }
  .header .headline { display: flex; -webkit-box-align: center; align-items=
: center; }
  .header .headline .icon { flex-shrink: 0; }
  .header .headline .title { margin-left: 12px; }
  body.rtl .header .headline .title { margin-right: 12px; }
  .image-container { align-self: center; padding: 1px; }
  .details, .review { display: flex; flex-direction: column; }
  .review { grid-area: review; border-top-right-radius: 4px; border-bottom-=
right-radius: 4px; padding: 18px 0px; display: -webkit-box; -webkit-box-ori=
ent: vertical; -webkit-box-direction: normal; -webkit-box-pack: center; jus=
tify-content: center; text-align: center; }
  .details { gap: 18px; }
  .header .headline .icon .has-stroke { stroke: rgb(255, 255, 255); }
  .score-text { font-size: 28px; }
  .blurb { font-size: 14px; }
