-index=3D"7">
                    <div class=3D"slide-wrapper">
                        <img src=3D"https://sm.ign.com/t/ign_ap/gallery/w/w=
olfenstei/wolfensteins-most-insane-moments_j1qf.200.png" alt=3D"Wolfenstein=
's Most Insane Moments" class=3D"gallery-image">
                    </div>
