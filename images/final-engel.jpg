ition-duration: 450ms; transition-timing-function: cubic-bezier(0.34, -0.09=
, 0.45, 1.18); margin-left: 96px; color: rgb(24, 28, 37); }
  body.iframe #btnoverlay + #mainblock { margin-left: 0px; width: 100%; }
  .side .sidebar-header { padding: 2.15625em 24px 0px; flex-basis: 80px; }
