m { display: none; }
  section.broll .info-mobile { display: block; color: rgb(65, 73, 90); font=
-size: 9px; letter-spacing: 0.06em; text-transform: uppercase; font-weight:=
 700; line-height: 1.35; }
  section.broll .m-mobile { grid-area: 2 / 1 / auto / -1; display: block; }
  section.broll .m h3 a { display: -webkit-box; -webkit-line-clamp: 4; -web=
kit-box-orient: vertical; overflow-y: hidden; text-overflow: ellipsis; font=
-size: 13px; letter-spacing: 0.005em; }
  section.broll .info-bottom a { -webkit-line-clamp: 2; }
